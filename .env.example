DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=your-channel-id-here
PLEX_URL=http://localhost:32400
# Optional: Plex token for library health checks (find at https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/)
PLEX_TOKEN=
# Comma-separated list of library names that must exist and have > 0 items (requires PLEX_TOKEN)
# PLEX_REQUIRED_LIBRARIES=Movies,TV Shows
CHECK_INTERVAL_SECONDS=300
ALERT_COOLDOWN_SECONDS=3600
STARTUP_DELAY_SECONDS=180
# Post a message to Discord when the bot starts up (default: false)
SEND_STARTUP_MESSAGE=false
# How many hours to snooze when someone reacts to an alert
SNOOZE_HOURS=4
# Quiet hours: suppress alerts during a time window (spans midnight, e.g. 23-7)
QUIET_HOURS_ENABLED=false
# QUIET_HOURS_START=23
# QUIET_HOURS_END=7
# QUIET_HOURS_TIMEZONE=UTC
# Optional: Discord user ID to @mention on alerts (leave blank to disable)
# To find your ID: Discord Settings > Advanced > enable Developer Mode, then right-click your name > Copy User ID
DISCORD_MENTION_USER_ID=
# Auto-restart: attempt to restart Plex Docker container on prolonged outage
PLEX_AUTO_RESTART=false
PLEX_CONTAINER_NAME=plex
# SSH host for restart (defaults to hostname from PLEX_URL)
# PLEX_SSH_HOST=
PLEX_SSH_USER=root
# Absolute path to SSH private key on the host (mounted into the container by docker-compose)
# PLEX_SSH_KEY_HOST_PATH=/home/user/.ssh/plexbot_key
# Number of alerts before auto-restart kicks in (default: 2, meaning first alert is notification-only)
RESTART_AFTER_ALERTS=2
# Seconds to wait after restart before re-checking Plex health
RESTART_CHECK_DELAY_SECONDS=60
# Timeout in seconds for the restart command (docker restart / SSH)
RESTART_TIMEOUT_SECONDS=120
# Scheduled restart: proactively restart Plex on a schedule (independent of outage detection)
PLEX_SCHEDULED_RESTART_ENABLED=false
# Timezone for scheduled restarts (default: UTC, e.g. America/Chicago)
# PLEX_SCHEDULED_RESTART_TIMEZONE=UTC
# Cron expression — takes precedence over frequency/time/day settings
# PLEX_SCHEDULED_RESTART_CRON=0 4 * * 0
# Frequency: daily, weekly, or monthly
# PLEX_SCHEDULED_RESTART_FREQUENCY=weekly
# Time of day to restart (24h "04:00" or 12h "4:00 AM", default: 04:00)
PLEX_SCHEDULED_RESTART_TIME=04:00
# Day of week for weekly restarts (monday-sunday, or mon-sun)
# PLEX_SCHEDULED_RESTART_DAY_OF_WEEK=sunday
# Day of month for monthly restarts (1-31, clamped to month's max days)
# PLEX_SCHEDULED_RESTART_DAY_OF_MONTH=1
# Skip scheduled restart if there are active streams (requires PLEX_TOKEN)
PLEX_SCHEDULED_RESTART_SKIP_IF_ACTIVE_STREAMS=true
# Post a Discord message when a scheduled restart succeeds (failures always notify)
PLEX_SCHEDULED_RESTART_NOTIFY_SUCCESS=false
