DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=your-channel-id-here
PLEX_URL=http://10.0.0.16:32400
# Optional: Plex token for library health checks (find at https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/)
PLEX_TOKEN=
# Comma-separated list of library names that must exist and have > 0 items (requires PLEX_TOKEN)
PLEX_REQUIRED_LIBRARIES=Movies,TV Shows
CHECK_INTERVAL_SECONDS=300
ALERT_COOLDOWN_SECONDS=3600
STARTUP_DELAY_SECONDS=180
# How many hours to snooze when someone reacts to an alert
SNOOZE_HOURS=4
# Optional: Discord user ID to @mention on alerts (leave blank to disable)
# To find your ID: Discord Settings > Advanced > enable Developer Mode, then right-click your name > Copy User ID
DISCORD_MENTION_USER_ID=
